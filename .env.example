# SIZO — Variables de entorno (Supabase)
# Copiar a .env y completar. NUNCA commitear .env al repositorio.
#
# Encontrar estos valores en:
# Supabase Dashboard → Project Settings → API

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Provisión del tenant inicial (scripts/provision-admin.mjs) ──
SIZO_ADMIN_EMAIL=tu@email.com
SIZO_ADMIN_NOMBRE=Tu Nombre
SIZO_TENANT_NOMBRE=Nombre de tu empresa o consultora
SIZO_TENANT_NOMBRE_CORTO=Nombre corto
SIZO_TENANT_TIPO=consultora
SIZO_TENANT_PLAN=starter
